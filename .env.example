# RELAY — environment template. Copy to .env and fill in. NEVER commit .env (golden rule #1).
#   cp .env.example .env
# Compose has safe dev defaults baked in (${VAR:-default}); the only value you must set for
# real use is OPENAI_API_KEY. Change the dev passwords before any non-local deployment.

# --- OpenAI (server-side only; required from M2 onward, unused at M1) ---
OPENAI_API_KEY=sk-REPLACE_ME

# --- Runtime ---
RELAY_ENV=dev

# --- PostgreSQL (metadata store) ---
POSTGRES_USER=relay
POSTGRES_PASSWORD=relay_dev_pw
POSTGRES_DB=relay
# Connection string the server uses (host 'postgres' is the compose service name):
DATABASE_URL=postgresql+asyncpg://relay:relay_dev_pw@postgres:5432/relay

# --- MinIO (S3-compatible blob storage for recordings) ---
MINIO_ROOT_USER=relay-minio
MINIO_ROOT_PASSWORD=relay_dev_minio_pw
MINIO_ENDPOINT=http://minio:9000
RELAY_RECORDINGS_BUCKET=relay-recordings
